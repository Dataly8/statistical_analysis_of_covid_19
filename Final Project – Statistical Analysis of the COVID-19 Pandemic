import csv
import io
import requests 
import plotly.graph_objects as go
import os
import base64
from openai import AzureOpenAI

def obtener_datos():
    """Obtiene los datos: usa la API si hay credenciales, o el CSV local si no las hay."""
    url = os.getenv("COVID_API_URL")
    api_key = os.getenv("COVID_API_KEY")

    try:
        if url and api_key:
            # Si hay credenciales, se conecta al endpoint en vivo
            respuesta = requests.get(url, headers={"x-api-key": api_key})
            respuesta.raise_for_status()
            texto_csv = respuesta.text
            print("Datos obtenidos desde la API.")
        else:
            # Si no hay credenciales, lee el CSV local incluido en el repositorio
            print("Sin credenciales: leyendo datos del archivo local CovidResultsCSV.csv")
            with open("CovidResultsCSV.csv", "r", encoding="utf-8") as f:
                texto_csv = f.read()

        # A partir de aquí, el parseo es idéntico en ambos casos
        lector = csv.DictReader(io.StringIO(texto_csv))
        datos = list(lector)
        print(f"Registros recibidos: {len(datos)}")
        return datos

    except (requests.exceptions.RequestException, FileNotFoundError) as e:
        print(f"Error al obtener los datos: {e}")
        return None



def buscar_por_rango(datos, fecha_inicio, fecha_fin):
    """Devuelve los registros que están dentro del rango de fechas especificado."""
    resultados = []
    for registro in datos:
        fecha = registro["date"]
        if fecha_inicio <= fecha <= fecha_fin:
            resultados.append(registro)
    return resultados

def pedir_fechas():
    """Pide al usuario la fecha de inicio y la de fin por pantalla. Devuelve ambas"""
    print("\nIntroduce el rango de fechas a consultar (formato YYYY-MM-DD):")
    fecha_inicio = input("Fecha de inicio: ").strip()
    fecha_fin = input("Fecha de fin: ")
    return fecha_inicio, fecha_fin

def preparar_datos(resultado):
    """Ordena los registros por fecha (de antiguo a reciente) y convierte los campos
    que vamos a graficar de texto a número."""
    resultado_ordenado = sorted(resultado, key=lambda r: r["date"])

    # Preparar listas vacías para cada cosa que vamos a dibujar (Plotly no dibuja diccionarios y necesita listas separadas)
    fechas = []
    positivos = []
    hospitalizados = []
    nuevos_casos = []

    # Recorrer cada registro, convertir a número y guardar en las listas:

    for r in resultado_ordenado:
        fechas.append(r["date"])
        positivos.append(int(r["positive"]) if r["positive"] else 0)
        hospitalizados.append(int(r["hospitalizedCumulative"]) if r["hospitalizedCumulative"] else 0)
        nuevos_casos.append(int(r["positiveIncrease"]) if r["positiveIncrease"] else 0)

    return fechas, positivos, hospitalizados, nuevos_casos

# Gráficos de líneas:

def grafico_lineas(fechas, positivos, hospitalizados):
    """Gráfico de líneas: evolución de casos positivos y hospitalizados acumulados en el tiempo."""
    figura = go.Figure()

    figura.add_trace(go.Scatter(
        x=fechas, y=positivos,
        mode="lines+markers", name="Casos positivos"
    ))
    figura.add_trace(go.Scatter(
        x=fechas, y=hospitalizados,
        mode="lines+markers", name="Hospitalizados acumulados"
    ))

    figura.update_layout(
        title="Evolución de casos positivos y hospitalizados",
        xaxis_title="Fecha",
        yaxis_title="Número de personas (acumulado)"
    )
    figura.show()

# Gráfico de barras:

def grafico_barras(fechas, nuevos_casos):
    """Gráfico de BARRAS: nuevos casos positivos cada día (dato diario)."""
    figura = go.Figure()
    figura.add_trace(go.Bar(
        x=fechas, y=nuevos_casos,
        name="Nuevos casos diarios"
    ))

    figura.update_layout(
        title="Nuevos casos positivos por día",
        xaxis_title="Fecha",
        yaxis_title="Casos nuevos en el día"
    )
    figura.show()

# Menú de elección dinámica
def menu_graficos(fechas, positivos, hospitalizados, nuevos_casos):
    """Pregunta la usuario qué gráfico quiere ver y lo muestra."""
    print("\n¿Qué gráfico deseas visualizar?")
    print(" 1 - Líneas: evolución de positivos y hospitalizados")
    print(" 2 - Barras: nuevos casos por día")

    opcion = input("Elige una opción (1/2): ").strip()

    if opcion == "1":
        grafico_lineas(fechas, positivos, hospitalizados)
    elif opcion =="2":
        grafico_barras(fechas, nuevos_casos)
    else:
        print("Opción no válida. No se puede mostrar ningún gráfico")


# NOTA: función completa que recplica el ejemplo del enunciado (SDK AzureOpenAI / gpt-image-2).
# La API devolvió error 401 (token de acceso caducado/inválido), verificando tanto con el SDK
# como con petición directa (headers Authorization:Bearer y api-key). 

# IMPORTANTE: La imagen adjunta se ha generado con una herramienta equivalente para cumplir el requisito de entrega.

def generar_imagen_ia():
    """Genera una imagen con IA (pizarra de colegio con estadística simulada) y la guarda como PNG."""
    endpoint = os.getenv("AZURE_OPENAI_ENDPOINT")
    api_key = os.getenv("AZURE_OPENAI_API_KEY")
    api_version = os.getenv("AZURE_OPENAI_API_VERSION", "2024-02-01")

    if not endpoint or not api_key:
        print("Faltan las variables de entorno. No se puede generar la imagen.")
        return

    client = AzureOpenAI(
        azure_endpoint=endpoint,
        api_key=api_key,
        api_version=api_version,
    )

    prompt = (
        "A photograph of a school classroom blackboard showing a simulated "
        "COVID-19 statistics chart drawn with chalk, with a bar graph and "
        "numbers representing daily cases"
    )

    try:
        resultado = client.images.generate(
            model="gpt-image-2",
            prompt=prompt,
            n=1,
            size="1024x1024",
        )
        item = resultado.data[0]

        if getattr(item, "url", None):
            import requests
            img = requests.get(item.url)
            with open("imagen_pizarra.png", "wb") as f:
                f.write(img.content)
        else:
            datos_img = base64.b64decode(item.b64_json)
            with open("imagen_pizarra.png", "wb") as f:
                f.write(datos_img)

        print("Imagen generada y guardada como 'imagen_pizarra.png'")

    except Exception as e:
        print(f"Error al generar la imagen: {e}")


if __name__ == "__main__":
    datos = obtener_datos()

    if datos is None:
        print("No se pudieron obtener los datos. Fin del programa.")
    else:
        generar_imagen_ia()   # Genera la imagen con IA una vez al arrancar

        # Bucle principal: se repite hasta que el usuario decida salir
        continuar = True
        while continuar:
            inicio, fin = pedir_fechas()
            resultado = buscar_por_rango(datos, inicio, fin)

            if len(resultado) == 0:
                print(f"\nNo se encontraron registros entre {inicio} y {fin}.")
            else:
                print(f"\nRegistros encontrados entre {inicio} y {fin}: {len(resultado)}")
                for r in resultado:
                    print(r["date"], "- positivos:", r["positive"])

                # Preparamos los datos y ofrecemos los gráficos
                fechas, positivos, hospitalizados, nuevos_casos = preparar_datos(resultado)
                menu_graficos(fechas, positivos, hospitalizados, nuevos_casos)

            # Preguntar al usuario si desea continuar
            respuesta = input("\n¿Desea realizar otra consulta? (si/no): ").strip().lower()
            if respuesta != "si":
                continuar = False
                print("Gracias por usar la aplicación. ¡Hasta pronto!")
